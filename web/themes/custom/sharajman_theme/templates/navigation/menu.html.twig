{% import _self as menus %}

{{ menus.menu_links(items, 0) }}

{% macro menu_links(items, menu_level) %}
  {% import _self as menus %}

  {% if items %}
    <ul>
      {% for item in items %}

        {% set has_children = item.below is not empty %}
        {% set link_attributes = create_attribute(item.url.options.attributes ?? {}) %}

        <li class="{{ has_children ? 'dropdown' }}">

          <a{{ link_attributes.addClass(item.in_active_trail ? 'active') }} href="{{ item.url }}">

            {% if has_children %}
              <span>{{ item.title }}</span>
              <i class="bi bi-chevron-down toggle-dropdown"></i>
            {% else %}
              {{ item.title }}
            {% endif %}

          </a>

          {% if has_children %}
            {{ menus.menu_links(item.below, menu_level + 1) }}
          {% endif %}

        </li>
        {% if logged_in %}        
          <li class="">
            <a target="_blank" href="/user/logout">Logout</a>
          </li>
        {% endif %}

      {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}