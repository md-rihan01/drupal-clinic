<section id="hero" class="hero section">

  <div class="container" data-aos="fade-up" data-aos-delay="100">

    <div class="row align-items-center">
      <div class="col-lg-6">
        <div class="hero-content">

          {# --- STATIC BADGES --- #}
          <div class="trust-badges mb-4" data-aos="fade-right" data-aos-delay="200">
            <div class="badge-item">
              <i class="bi bi-shield-check"></i>
              <span>Accredited</span>
            </div>
            <div class="badge-item">
              <i class="bi bi-clock"></i>
              <span>24/7 Emergency</span>
            </div>
            <div class="badge-item">
              <i class="bi bi-star-fill"></i>
              <span>4.9/5 Rating</span>
            </div>
          </div>

          {# --- TITLE (Dynamic) --- #}
          <h1 data-aos="fade-right" data-aos-delay="300">
            {{ paragraph.field_title.value|raw }}
          </h1>

          {# --- DESCRIPTION (Dynamic) --- #}
          <p class="hero-description" data-aos="fade-right" data-aos-delay="400">
            {{ paragraph.field_description.value }}
          </p>

          {# --- STATS (Dynamic Numbers Only) --- #}
          <div class="hero-stats mb-4" data-aos="fade-right" data-aos-delay="500">

            <div class="stat-item">
              <h3>
                <span data-purecounter-start="0" data-purecounter-end="{{ paragraph.field_years_experience.value }}" data-purecounter-duration="2" class="purecounter"></span>+
              </h3>
              <p>Years Experience</p>
            </div>

            <div class="stat-item">
              <h3>
                <span data-purecounter-start="0" data-purecounter-end="{{ paragraph.field_patients_treated.value }}" data-purecounter-duration="2" class="purecounter"></span>+
              </h3>
              <p>Patients Treated</p>
            </div>

            <div class="stat-item">
              <h3><span data-purecounter-start="0" data-purecounter-end="{{ paragraph.field_medical_experts.value }}" data-purecounter-duration="2" class="purecounter"></span>+</h3>
              <p>Medical Experts</p>
            </div>

          </div>

          {# --- STATIC BUTTONS --- #}
          <div class="hero-actions" data-aos="fade-right" data-aos-delay="600">
            <a href="#" class="btn btn-primary">Book Appointment</a>
            <a href="#" class="btn btn-outline glightbox">
              <i class="bi bi-play-circle me-2"></i>
              Watch Our Story
            </a>
          </div>

          {# --- EMERGENCY PHONE (Dynamic) --- #}
          <div class="emergency-contact" data-aos="fade-right" data-aos-delay="700">
            <div class="emergency-icon">
              <i class="bi bi-telephone-fill"></i>
            </div>
            <div class="emergency-info">
              <small>Emergency Hotline</small>
              <strong>{{ paragraph.field_emergency_phone.value }}</strong>
            </div>
          </div>

        </div>
      </div>

      {# --- HERO IMAGE (Dynamic) --- #}
      <div class="col-lg-6">
        <div class="hero-visual" data-aos="fade-left" data-aos-delay="400">

          <div class="main-image">
            {% if paragraph.field_hero_image.entity %}
              <img src="{{ file_url(paragraph.field_hero_image.entity.uri.value) }}"
                   alt=""
                   class="img-fluid">
            {% endif %}
            <div class="floating-card appointment-card">
              <div class="card-icon">
                <i class="bi bi-calendar-check"></i>
              </div>
              <div class="card-content">
                <h6>Next Available</h6>
                <p>Today 2:30 PM</p>
                <small>Dr. Sarah Johnson</small>
              </div>
            </div>
            <div class="floating-card rating-card">
              <div class="card-content">
                <div class="rating-stars">
                  <i class="bi bi-star-fill"></i>
                  <i class="bi bi-star-fill"></i>
                  <i class="bi bi-star-fill"></i>
                  <i class="bi bi-star-fill"></i>
                  <i class="bi bi-star-half"></i>
                </div>
                <h6>4.5/5</h6>
                <small>1,234 Reviews</small>
              </div>
            </div>
          </div>
          <div class="background-elements">
            <div class="element element-1"></div>
            <div class="element element-2"></div>
            <div class="element element-3"></div>
          </div>

        </div>
      </div>

    </div>

  </div>

</section>
